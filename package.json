{
  "name": "personalblog",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/generate-content-manifest.mjs && node scripts/generate-music-manifest.mjs",
    "dev": "nodemon --watch src --watch content --ext ts,md --ignore src/generated --exec \"pnpm run predev && vite\"",
    "prebuild": "node scripts/generate-content-manifest.mjs && node scripts/generate-music-manifest.mjs",
    "build": "pnpm run prebuild && node scripts/generate-sitemap.mjs && vue-tsc -b && vite build",
    "postbuild": "node scripts/copy-404.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "element-plus": "^2.14.1",
    "github-markdown-css": "^5.9.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-link-attributes": "^4.0.1",
    "mermaid": "^11.15.0",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "nodemon": "^3.1.14",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vue-tsc": "^3.2.8"
  }
}
